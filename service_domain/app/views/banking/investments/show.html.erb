<div style="max-width: 720px; margin: 32px auto; padding: 0 16px;">
  <div style="display:flex; align-items:center; justify-content: space-between; gap: 12px;">
    <div>
      <h1 style="margin: 0;"><%= @investment.name %></h1>
      <p style="margin: 6px 0 0; color:#4b5563;">domain: banking</p>
    </div>
    <div style="display:flex; gap: 10px;">
      <%= link_to "Back", banking_investments_path, style: "padding: 8px 12px; border: 1px solid #d1d5db; border-radius: 6px; text-decoration:none;" %>
      <%= link_to "Edit", edit_banking_investment_path(@investment), style: "padding: 8px 12px; border: 1px solid #111827; border-radius: 6px; text-decoration:none;" %>
    </div>
  </div>

  <% if notice.present? %>
    <div style="margin-top: 16px; padding: 10px 12px; border: 1px solid #bbf7d0; background: #f0fdf4; border-radius: 6px;">
      <%= notice %>
    </div>
  <% end %>

  <div style="margin-top: 18px; border: 1px solid #e5e7eb; border-radius: 8px; padding: 14px;">
    <dl style="margin: 0; display:grid; grid-template-columns: 180px 1fr; gap: 10px 14px;">
      <dt style="color:#6b7280;">Kind</dt>
      <dd style="margin: 0;"><%= @investment.kind %></dd>
      <dt style="color:#6b7280;">Amount (cents)</dt>
      <dd style="margin: 0;"><%= @investment.amount_cents %></dd>
      <dt style="color:#6b7280;">Purchased on</dt>
      <dd style="margin: 0;"><%= @investment.purchased_on %></dd>
      <dt style="color:#6b7280;">Created</dt>
      <dd style="margin: 0;"><%= @investment.created_at %></dd>
    </dl>
  </div>

  <div style="margin-top: 16px;">
    <%= button_to "Delete", banking_investment_path(@investment), method: :delete, data: { turbo_confirm: "Delete this investment?" } %>
  </div>
</div>

